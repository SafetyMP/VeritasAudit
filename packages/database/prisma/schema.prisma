datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Transaction {
  id        String   @id
  timestamp DateTime @default(now())
  sender    String
  recipient String
  amount    Float
  currency  String
  status    String   // 'pending' | 'completed' | 'failed' | 'flagged'
  maskedPii Boolean  @default(false)
}

model AuditReceipt {
  id                  String   @id
  type                String   @default("protectmcp:decision")
  tool_name           String
  decision            String   // 'allow' | 'deny'
  policy_digest       String
  issued_at           DateTime @default(now())
  issuer_id           String
  reason              String?
  claimed_issuer_tier Int?
  signature_alg       String   @default("EdDSA")
  signature_sig       String
}

model SecurityFinding {
  vector      String   @id
  title       String
  severity    String   // 'High' | 'Medium' | 'Low' | 'Info'
  file        String
  step        String
  impact      String
  evidence    String
  dataFlow    String[]
  remediation String
  amplifiedBy String[]
}

model LogEntry {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  level     String   // 'info' | 'warn' | 'error' | 'security'
  message   String
  metadata  Json?
}

model CommandLog {
  id            String   @id
  timestamp     DateTime @default(now())
  command       String
  user          String
  role          String
  status        String   // 'success' | 'failed'
  exitCode      Int
  cedarDecision String   // 'allow' | 'deny'
}

model PendingAction {
  id             String              @id @default(uuid())
  createdAt      DateTime            @default(now())
  expiresAt      DateTime
  command        String
  initiator      String
  role           String
  requiredVotes  Int                 @default(2)
  status         String              // 'pending' | 'approved' | 'rejected' | 'expired'
  approvals      ConsensusApproval[]
}

model ConsensusApproval {
  id              String        @id @default(uuid())
  actionId        String
  action          PendingAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  timestamp       DateTime      @default(now())
  approver        String
  role            String
  signature       String        // Cryptographic Ed25519 signature of the approval
}

model FilesystemDrift {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  filePath   String
  changeType String   // 'modified' | 'added' | 'deleted'
  diff       String?  @db.Text
  reconciled Boolean  @default(false)
}



